#!/usr/bin/env bash
# macOS .app entry point. Thin: sets paths + native prompts, then delegates to the
# shared bootstrap. Self-contained — bootstrap.sh is copied into Resources/ at build.
set -euo pipefail

BUNDLE="$(cd "$(dirname "$0")/.." && pwd)"          # …/JupyterBioacoustic.app/Contents
RES="$BUNDLE/Resources"
export APP_SUPPORT="$HOME/Library/Application Support/JupyterBioacoustic"
# The installer copies the payload (pixi binary + manifest + lock) into Resources/payload.
export PAYLOAD="$RES/payload"

mkdir -p "$APP_SUPPORT"

# Native helpers used by bootstrap.sh (optional hooks it probes for).
_notify_impl() { osascript -e "display notification \"$1\" with title \"Jupyter Bioacoustic\"" >/dev/null 2>&1 || true; }
_prompt_update() {
  osascript -e 'button returned of (display dialog "An update for Jupyter Bioacoustic is available. Update now?" buttons {"Later","Update"} default button "Update" with title "Jupyter Bioacoustic")' 2>/dev/null \
    | grep -q "Update"
}
export -f _notify_impl _prompt_update

# shellcheck disable=SC1091
source "$RES/bootstrap.sh"
bootstrap_and_launch
