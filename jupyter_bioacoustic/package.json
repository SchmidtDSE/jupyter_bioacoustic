{
  "name": "jupyter-bioacoustic",
  "version": "0.6.7",
  "description": "JupyterLab bioacoustic audio review plugin",
  "keywords": [
    "jupyter",
    "jupyterlab",
    "jupyterlab-extension"
  ],
  "license": "MIT",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "files": [
    "lib/**/*.{d.ts,js,js.map}"
  ],
  "scripts": {
    "build:labextension:dev": "rimraf labextension && jupyter labextension build --development True .",
    "build:labextension": "rimraf labextension && jupyter labextension build .",
    "build:prod": "jlpm run build:lib:prod && jlpm run build:labextension",
    "build:lib": "tsc --sourceMap",
    "build:lib:prod": "tsc",
    "watch:src": "tsc -w --sourceMap",
    "clean": "rimraf lib labextension tsconfig.tsbuildinfo",
    "test": "jest"
  },
  "dependencies": {
    "@jupyterlab/application": "^4.0.0",
    "@jupyterlab/apputils": "^4.0.0",
    "@jupyterlab/coreutils": "^6.0.0",
    "@jupyterlab/filebrowser": "^4.0.0",
    "@jupyterlab/launcher": "^4.0.0",
    "@jupyterlab/notebook": "^4.0.0",
    "@jupyterlab/ui-components": "^4.0.0",
    "@lumino/widgets": "^2.0.0"
  },
  "devDependencies": {
    "@jupyterlab/builder": "^4.0.0",
    "@types/jest": "^30.0.0",
    "jest": "^30.4.2",
    "rimraf": "^5.0.0",
    "ts-jest": "^29.4.9",
    "typescript": "~5.1.0"
  },
  "jupyterlab": {
    "extension": true,
    "outputDir": "labextension"
  }
}
